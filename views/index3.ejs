<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Gestión de Vehículos - eXist-db</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="container mt-5">
    <h2>Añadir Vehículo</h2>
    <form action="/add" method="POST" class="row g-3 mb-5">
        <div class="col-md-2"><input type="text" name="id" class="form-control" placeholder="ID" required></div>
        <div class="col-md-2"><input type="text" name="marca" class="form-control" placeholder="Marca" required></div>
        <div class="col-md-2"><input type="text" name="modelo" class="form-control" placeholder="Modelo" required></div>
        <div class="col-md-2"><input type="number" name="precio" class="form-control" placeholder="Precio" required></div>
        <div class="col-md-2"><input type="text" name="tipo_motor" class="form-control" placeholder="Motor" required></div>
        <div class="col-md-2"><button type="submit" class="btn btn-primary w-100">Guardar</button></div>
    </form>

    <hr>

    <h2>Filtro Avanzado (XQuery)</h2>
    <form id="filterForm" class="row g-3 mb-4">
        <div class="col-md-3"><input type="text" id="f_marca" class="form-control" placeholder="Marca (ej. Toyota)"></div>
        <div class="col-md-3"><input type="number" id="f_min" class="form-control" placeholder="Precio Min"></div>
        <div class="col-md-3"><input type="number" id="f_max" class="form-control" placeholder="Precio Max"></div>
        <div class="col-md-3"><button type="button" onclick="aplicarFiltro()" class="btn btn-success w-100">Filtrar</button></div>
    </form>

    <h2>Inventario Actual</h2>
    <div id="results" class="mt-3">
        <!-- Aquí puedes mostrar el XML crudo o parsearlo -->
        <pre class="bg-light p-3"><code><%= data %></code></pre>
    </div>

    <script>
        async function aplicarFiltro() {
            const data = {
                marca: document.getElementById('f_marca').value,
                min: document.getElementById('f_min').value,
                max: document.getElementById('f_max').value
            };
            const response = await fetch('/api/filter', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            });
            const xmlText = await response.text();
            document.getElementById('results').innerHTML = `<pre class="bg-light p-3"><code>${xmlText}</code></pre>`;
        }
    </script>
</body>
</html>